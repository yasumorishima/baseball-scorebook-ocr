# =============================================================================
# 草野球スコアブック PWA 環境変数
#
# 1. このファイルを `.env.local` にコピーする
# 2. Supabase プロジェクト作成: https://supabase.com/dashboard
#    - 無料枠で OK。Region は近い順 (ap-northeast-1 > us-west-1)
# 3. Project Settings > API から URL と anon key を貼る
# 4. Project Settings > Database > SQL Editor で
#    `supabase/migrations/0001_init.sql` を実行
# 5. Authentication > Providers で Email / Google を有効化
#
# service_role key は絶対にクライアントに置かない（§10.5 RLS bypass）。
# サーバ側の migration / admin 操作でのみ使用し、GitHub Actions secret 等に閉じる。
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>

# ANTHROPIC_API_KEY は既存 OCR パイプライン用。PWA 側では直接使わない。
# Day 2 では Server Action / Route Handler 経由でのみ呼び出す想定。
ANTHROPIC_API_KEY=
