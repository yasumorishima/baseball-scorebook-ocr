{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "incremental": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["./app/*"],
      "@/client/*": ["./src/client/*"],
      "@/pwa/*": ["./src/pwa/*"],
      "@/src/*": ["./src/*"]
    }
  },
  "include": [
    "experiments/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "next.config.ts",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
